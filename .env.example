# =============================================
# BESTSELLERS AI — Environment Variables
# =============================================

# DATABASE
DATABASE_URL="postgresql://bestsellers:bestsellers_dev@localhost:5432/bestsellers?schema=public"

# REDIS
REDIS_URL="redis://localhost:6379"

# AUTH
JWT_SECRET="your-jwt-secret-min-32-chars-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars-change-in-production"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# STRIPE
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# N8N
N8N_WEBHOOK_BASE_URL="https://n8n.example.com/webhook"
N8N_WEBHOOK_PREVIEW="/preview"
N8N_WEBHOOK_GENERATION="/generate-book"
N8N_WEBHOOK_ADDON="/process-addon"
N8N_CALLBACK_SECRET="shared-secret-between-api-and-n8n"

# STORAGE (Cloudflare R2)
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY="your-access-key"
R2_SECRET_KEY="your-secret-key"
R2_BUCKET="bestsellers-files"
R2_PUBLIC_URL="https://files.bestsellers.ai"

# EMAIL
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@bestsellers.ai"

# APP
NODE_ENV="development"
API_PORT=3001
API_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# FRONTEND (NEXT_PUBLIC_*)
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_APP_URL="http://localhost:3000"
