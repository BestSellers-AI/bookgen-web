# =============================================
# BESTSELLERS AI — Environment Variables
# =============================================
# Copy this file to:
#   .env.staging     (staging deploy)
#   .env.production  (production deploy)
# Or use the per-app .env.example files:
#   apps/api/.env.example  → apps/api/.env
#   apps/web/.env.example  → apps/web/.env

# ===========================================
# API (apps/api)
# ===========================================

# ─── APP ─────────────────────────────────────
NODE_ENV="development"
API_PORT=3001
API_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# ─── DATABASE ────────────────────────────────
# Docker Compose maps host 5433 → container 5432
DATABASE_URL="postgresql://bestsellers:bestsellers_dev@localhost:5433/bestsellers?schema=public"

# ─── REDIS ───────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── AUTH ────────────────────────────────────
JWT_SECRET="your-jwt-secret-min-32-chars-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars-change-in-production"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── STRIPE ──────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── N8N ─────────────────────────────────────
N8N_WEBHOOK_BASE_URL="http://localhost:5678/webhook"
N8N_WEBHOOK_PREVIEW="/preview"
N8N_WEBHOOK_GENERATION="/generate-book"
N8N_WEBHOOK_ADDON="/process-addon"
N8N_WEBHOOK_PREVIEW_COMPLETE="/preview-complete"
# Must be >= 16 characters. Shared between API and n8n.
N8N_CALLBACK_SECRET="dev-n8n-callback-secret-local"
N8N_CALLBACK_BASE_URL="http://localhost:3001"

# ─── STORAGE (S3) ────────────────────────────
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="bestsellers-files"
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_PUBLIC_URL=""

# ─── EMAIL ───────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@updates.bestsellers-ai.com"

# ─── LLM (OpenRouter) ──────────────────────
OPENROUTER_API_KEY=""
LLM_MODEL_PREVIEW="x-ai/grok-4.1-fast"
LLM_MODEL_GENERATION="openai/gpt-5-nano"
LLM_MODEL_IMAGE="google/gemini-3.1-flash-image-preview"
LLM_MAX_RETRIES=3
LLM_TIMEOUT_MS=120000

# ─── GENERATION (BullMQ) ──────────────────
USE_INTERNAL_GENERATION=false
GENERATION_CONCURRENCY=2
GENERATION_JOB_TIMEOUT_MS=2700000

# ─── FACEBOOK (CAPI) ───────────────────────
FACEBOOK_PIXEL_ID=""
FACEBOOK_CAPI_ACCESS_TOKEN=""
FACEBOOK_TEST_EVENT_CODE=""

# ===========================================
# WEB (apps/web)
# ===========================================

# ─── API ─────────────────────────────────────
# Must include /api prefix (NestJS global prefix)
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# ─── GOOGLE OAUTH ────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# ─── ANALYTICS ──────────────────────────────
NEXT_PUBLIC_CLARITY_ID=""
NEXT_PUBLIC_FB_PIXEL_ID=""

# ─── OPENAI (Chat Planning) ────────────────
# Used by both API and Web
OPENAI_API_KEY=""
