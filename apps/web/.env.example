# =============================================
# BESTSELLERS AI — Frontend (Next.js)
# =============================================
# Copy to: apps/web/.env.local

# ─── API ─────────────────────────────────────
# Must include /api prefix (NestJS global prefix)
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# ─── GOOGLE OAUTH ────────────────────────────
# Same client ID used in backend. Leave empty to hide Google login button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# ─── ANALYTICS ──────────────────────────────
# Microsoft Clarity project ID (leave empty to disable)
NEXT_PUBLIC_CLARITY_ID=""
# Facebook Pixel ID (leave empty to disable)
NEXT_PUBLIC_FB_PIXEL_ID=""

# ─── OPENAI (Chat Planning) ────────────────
OPENAI_API_KEY=""
